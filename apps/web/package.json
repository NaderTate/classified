    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@classified/shared": "workspace:*",
    "@heroui/react": "^3.0.0",
    "@heroui/styles": "^3.0.0",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.120.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/router-plugin": "^1.120.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.3.3"
