    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
